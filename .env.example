# =============================================
# Compliance Track - Production Environment
# =============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NextAuth Configuration
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your_nextauth_secret_here

# Stripe Configuration (Production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration - Resend
RESEND_API_KEY=re_your_resend_api_key

# Cron Job Security
CRON_SECRET=your_cron_secret_key_here

# =============================================
# Optional Configuration
# =============================================

# 46elks SMS Configuration (Stored in database, but can be set here for initial setup)
# ELKS_USERNAME=your_46elks_username
# ELKS_PASSWORD=your_46elks_password

# Application Settings (Defaults, can be overridden in admin panel)
DEFAULT_MONTHLY_PRICE=29.99
DEFAULT_TRIAL_DAYS=30

# =============================================
# Development Overrides (Optional)
# =============================================

# Uncomment for development
# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
