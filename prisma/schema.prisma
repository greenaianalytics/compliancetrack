// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core tables - match existing Supabase schema
model User {
  id        String    @id
  email     String?   @unique
  name      String?
  verified  Boolean   @default(false)
  role      String    @default("user")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  tenants           TenantUser[]
  complianceItems   ComplianceItem[]
  customTasks       CustomTask[]

  @@map("users")
}

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  naceCode  String?  @map("nace_code") // Store the primary NACE code for this tenant
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  users              TenantUser[]
  complianceItems    ComplianceItem[]
  complianceTaskInstances ComplianceTaskInstance[]
  customTasks        CustomTask[]

  @@map("tenants")
}

model TenantUser {
  tenantId  String @db.Uuid
  userId    String
  role      String @default("member") // 'admin', 'member'
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId])
  @@map("tenant_users")
}

// Compliance tracking
model ComplianceItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  title     String
  status    String   @default("open") // 'open', 'completed'
  year      Int      // Which compliance year this task is for
  createdBy String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User? @relation(fields: [createdBy], references: [id])

  @@map("compliance_items")
}

// Templates for NACE-based compliance tasks (imported from JSONs)
model ComplianceTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  naceCode     String   @map("nace_code")
  title        String
  description  String?
  category     String?  // e.g., "GDPR", "Health & Safety"
  frequency    String   @default("yearly") // 'yearly', 'monthly', 'quarterly'
  templateData Json     @map("template_data") // Store any additional metadata
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  instances ComplianceTaskInstance[]

  @@unique([naceCode, title]) // Ensure no duplicate templates per NACE
  @@map("compliance_templates")
}

// Instances of compliance templates populated per year
model ComplianceTaskInstance {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  templateId String   @db.Uuid
  year       Int      // The year this task was populated for
  title      String
  dueDate    DateTime @map("due_date")
  status     String   @default("pending") // 'pending', 'completed', 'overdue'
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template ComplianceTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([tenantId, year])
  @@map("compliance_task_instances")
}

// Custom tasks created by users
model CustomTask {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  createdBy         String
  title             String
  description       String?
  dueDate           DateTime  @map("due_date")
  isRecurring       Boolean   @default(false) @map("is_recurring")
  recurrencePattern String?   @map("recurrence_pattern") // 'yearly', 'monthly', etc.
  occurrenceYear    Int?      @map("occurrence_year") // Which year this custom task is for
  status            String    @default("pending") // 'pending', 'completed'
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([tenantId, occurrenceYear])
  @@map("custom_tasks")
}
